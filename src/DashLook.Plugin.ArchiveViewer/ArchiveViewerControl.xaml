<UserControl x:Class="DashLook.Plugin.ArchiveViewer.ArchiveViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#181825">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search bar -->
        <Border Grid.Row="0" Background="#1E1E2E" Padding="8,6">
            <TextBox x:Name="SearchBox"
                     Background="#313244"
                     Foreground="#CDD6F4"
                     BorderThickness="0"
                     Padding="8,4"
                     FontSize="13"
                     TextChanged="SearchBox_TextChanged">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="🔍  Filter files…"
                                                           Foreground="#585B70"
                                                           Margin="8,4"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </Border>

        <!-- File list -->
        <ListView x:Name="FileList"
                  Grid.Row="1"
                  Background="#181825"
                  Foreground="#CDD6F4"
                  BorderThickness="0"
                  FontSize="12">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name"        Width="340" DisplayMemberBinding="{Binding DisplayName}"/>
                    <GridViewColumn Header="Size"        Width="90"  DisplayMemberBinding="{Binding SizeText}"/>
                    <GridViewColumn Header="Compressed"  Width="90"  DisplayMemberBinding="{Binding CompressedText}"/>
                    <GridViewColumn Header="Modified"    Width="140" DisplayMemberBinding="{Binding ModifiedText}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#1E1E2E" Padding="12,6">
            <TextBlock x:Name="FooterText"
                       Foreground="#A6ADC8"
                       FontSize="11"/>
        </Border>
    </Grid>
</UserControl>
