<UserControl x:Class="DashLook.Plugin.ArchiveViewer.ArchiveViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBackground}">
    <Grid Background="{DynamicResource ContentBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource WindowBackground}" Padding="8,6">
            <TextBox x:Name="SearchBox"
                     Background="{DynamicResource SurfaceBackground}"
                     Foreground="{DynamicResource TextPrimary}"
                     BorderBrush="{DynamicResource BorderLight}"
                     BorderThickness="1"
                     Padding="8,4"
                     FontSize="13"
                     TextChanged="SearchBox_TextChanged">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="Search archive contents"
                                                           Foreground="{DynamicResource TextDisabled}"
                                                           Margin="8,4"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </Border>

        <ListView x:Name="FileList"
                  Grid.Row="1"
                  Background="{DynamicResource ContentBackground}"
                  Foreground="{DynamicResource TextPrimary}"
                  BorderThickness="0"
                  FontSize="12">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name" Width="340" DisplayMemberBinding="{Binding DisplayName}"/>
                    <GridViewColumn Header="Size" Width="90" DisplayMemberBinding="{Binding SizeText}"/>
                    <GridViewColumn Header="Compressed" Width="90" DisplayMemberBinding="{Binding CompressedText}"/>
                    <GridViewColumn Header="Modified" Width="140" DisplayMemberBinding="{Binding ModifiedText}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <Border Grid.Row="2" Background="{DynamicResource WindowBackground}" Padding="12,6">
            <TextBlock x:Name="FooterText"
                       Foreground="{DynamicResource TextSecondary}"
                       FontSize="11"/>
        </Border>
    </Grid>
</UserControl>
