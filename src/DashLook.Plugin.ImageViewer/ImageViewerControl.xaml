<UserControl x:Class="DashLook.Plugin.ImageViewer.ImageViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid>
        <!-- Checkerboard background (shows transparency) -->
        <Rectangle>
            <Rectangle.Fill>
                <DrawingBrush TileMode="Tile"
                              Viewport="0,0,16,16"
                              ViewportUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <DrawingGroup>
                            <GeometryDrawing Brush="#222233">
                                <GeometryDrawing.Geometry>
                                    <RectangleGeometry Rect="0,0,16,16"/>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                            <GeometryDrawing Brush="#2A2A3E">
                                <GeometryDrawing.Geometry>
                                    <GeometryGroup>
                                        <RectangleGeometry Rect="0,0,8,8"/>
                                        <RectangleGeometry Rect="8,8,8,8"/>
                                    </GeometryGroup>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingGroup>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Zoomable scroll viewer -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      x:Name="Scroller">
            <Image x:Name="MainImage"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   MouseWheel="Image_MouseWheel"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="16">
                <Image.LayoutTransform>
                    <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1"/>
                </Image.LayoutTransform>
            </Image>
        </ScrollViewer>

        <!-- Zoom indicator -->
        <Border x:Name="ZoomIndicator"
                Background="#AA1E1E2E"
                CornerRadius="4"
                Padding="6,3"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="8"
                Opacity="0">
            <TextBlock x:Name="ZoomText"
                       Text="100%"
                       Foreground="#CDD6F4"
                       FontSize="11"/>
        </Border>
    </Grid>
</UserControl>
