<Window x:Class="DashLook.Windows.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Available — DashLook"
        Width="480" Height="320"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0" CornerRadius="0" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Border Background="{DynamicResource WindowBackground}" CornerRadius="12" Margin="8"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseDown">
                <TextBlock Text="🚀  Update Available"
                           Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="16,0"/>
                <Button Content="✕" Style="{StaticResource CloseButton}"
                        HorizontalAlignment="Right" Margin="0,0,8,0"
                        Click="Cancel_Click"/>
            </Grid>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="20,8,20,0">
                <!-- Version info -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{DynamicResource SurfaceBackground}" CornerRadius="8" Padding="12,8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Current" Foreground="{DynamicResource TextDisabled}" FontSize="10"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="CurrentVersionText" Foreground="{DynamicResource TextSecondary}"
                                       FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Column="1" Text="→" FontSize="20" Foreground="{DynamicResource AccentColor}"
                               VerticalAlignment="Center" Margin="12,0"/>

                    <Border Grid.Column="2" Background="{DynamicResource SurfaceBackground}" CornerRadius="8" Padding="12,8"
                            BorderBrush="{DynamicResource AccentColor}" BorderThickness="1">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Latest" Foreground="{DynamicResource AccentColor}" FontSize="10"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="LatestVersionText" Foreground="{DynamicResource AccentColor}"
                                       FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Release notes -->
                <TextBlock Text="What's new:" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/>
                <Border Background="{DynamicResource ContentBackground}" CornerRadius="6" Padding="10" Height="80">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ReleaseNotesText"
                                   Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>

                <!-- Progress bar (hidden until download starts) -->
                <Grid x:Name="ProgressArea" Visibility="Collapsed" Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="ProgressText" Foreground="{DynamicResource TextSecondary}" FontSize="11"
                               Margin="0,0,0,4"/>
                    <ProgressBar x:Name="ProgressBar" Grid.Row="1" Height="8"
                                 Minimum="0" Maximum="100"
                                 Background="{DynamicResource SurfaceBackground}" Foreground="{DynamicResource AccentColor}"/>
                </Grid>
            </StackPanel>

            <!-- Buttons -->
            <Border Grid.Row="2" Padding="20,12" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="PublishedText" Grid.Column="0"
                               Foreground="{DynamicResource TextDisabled}" FontSize="10"
                               VerticalAlignment="Center"/>

                    <Button x:Name="SkipBtn" Grid.Column="1"
                            Content="Skip this version"
                            Background="Transparent" Foreground="{DynamicResource TextDisabled}"
                            BorderThickness="0" Padding="12,8"
                            Cursor="Hand" Click="Cancel_Click"/>

                    <Button x:Name="UpdateBtn" Grid.Column="3"
                            Content="⬇  Download &amp; Install"
                            Background="{DynamicResource AccentColor}" Foreground="{DynamicResource AccentForeground}"
                            BorderThickness="0" Padding="16,9"
                            FontWeight="SemiBold" Cursor="Hand"
                            Click="Update_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
