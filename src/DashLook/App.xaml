<Application x:Class="DashLook.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Theme dict loaded first — ThemeManager swaps this at runtime -->
                <ResourceDictionary Source="Resources/Themes/Dark.xaml"/>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Tray icon defined here so it persists across window open/close -->
            <tb:TaskbarIcon x:Key="TrayIcon"
                            IconSource="/assets/DashLook.ico"
                            ToolTipText="DashLook — Press Space to preview files"
                            Visibility="Visible"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
