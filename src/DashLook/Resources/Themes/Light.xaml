<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="WindowBackground" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="SurfaceBackground" Color="#EEF2F7"/>
    <SolidColorBrush x:Key="ContentBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="StatusBarBackground" Color="#E8EDF4"/>
    <SolidColorBrush x:Key="HoverBackground" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="PressedBackground" Color="#D7E0EA"/>

    <SolidColorBrush x:Key="TextPrimary" Color="#0F172A"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#475569"/>
    <SolidColorBrush x:Key="TextDisabled" Color="#64748B"/>

    <SolidColorBrush x:Key="AccentColor" Color="#2563EB"/>
    <SolidColorBrush x:Key="AccentLight" Color="#60A5FA"/>
    <SolidColorBrush x:Key="AccentDark" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="AccentForeground" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="ErrorColor" Color="#DC2626"/>
    <SolidColorBrush x:Key="SuccessColor" Color="#16A34A"/>
    <SolidColorBrush x:Key="WarningColor" Color="#D97706"/>

    <SolidColorBrush x:Key="CloseButtonHover" Color="#DC2626"/>
    <SolidColorBrush x:Key="TitleBarButtonHover" Color="#E2E8F0"/>

    <SolidColorBrush x:Key="BorderColor" Color="#D8E1EB"/>
    <SolidColorBrush x:Key="BorderLight" Color="#CBD5E1"/>

    <DropShadowEffect x:Key="WindowShadow"
                      Color="#94A3B8"
                      Direction="270"
                      ShadowDepth="2"
                      BlurRadius="18"
                      Opacity="0.22"/>

</ResourceDictionary>
