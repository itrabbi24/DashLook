<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <UseWPF>true</UseWPF>
    <AssemblyName>DashLook</AssemblyName>
    <RootNamespace>DashLook</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>..\..\assets\DashLook.ico</ApplicationIcon>
    <Version>1.0.15</Version>
    <Authors>ARG RABBI</Authors>
    <Description>Instant file preview for Windows — press Space to preview any file</Description>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Platforms>AnyCPU;x64</Platforms>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\DashLook.Common\DashLook.Common.csproj" />
    <ProjectReference Include="..\DashLook.Plugin.TextViewer\DashLook.Plugin.TextViewer.csproj" />
    <ProjectReference Include="..\DashLook.Plugin.ImageViewer\DashLook.Plugin.ImageViewer.csproj" />
    <ProjectReference Include="..\DashLook.Plugin.PdfViewer\DashLook.Plugin.PdfViewer.csproj" />
    <ProjectReference Include="..\DashLook.Plugin.HtmlViewer\DashLook.Plugin.HtmlViewer.csproj" />
    <ProjectReference Include="..\DashLook.Plugin.MarkdownViewer\DashLook.Plugin.MarkdownViewer.csproj" />
    <ProjectReference Include="..\DashLook.Plugin.ArchiveViewer\DashLook.Plugin.ArchiveViewer.csproj" />
    <ProjectReference Include="..\DashLook.Plugin.FontViewer\DashLook.Plugin.FontViewer.csproj" />
    <ProjectReference Include="..\DashLook.Plugin.VideoViewer\DashLook.Plugin.VideoViewer.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.2792.45" />
    <PackageReference Include="Hardcodet.NotifyIcon.Wpf" Version="1.1.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

  <ItemGroup>
    <!-- Theme XAML files must be included as Resource so pack:// URIs resolve at runtime -->
    <Resource Include="Resources\Themes\Dark.xaml"/>
    <Resource Include="Resources\Themes\Light.xaml"/>
    <Resource Include="Resources\dashlook_tray.ico"/>
  </ItemGroup>

</Project>



