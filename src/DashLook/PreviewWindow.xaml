<Window x:Class="DashLook.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        MinWidth="400"
        MinHeight="300"
        Width="960"
        Height="660"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="False"
        d:DesignHeight="660"
        d:DesignWidth="960"
        KeyDown="Window_KeyDown">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource WindowBackground}"
            CornerRadius="12"
            Margin="6"
            Effect="{DynamicResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="FileTypeIcon"
                           Grid.Column="0"
                           Text="??"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <TextBlock x:Name="TitleText"
                           Grid.Column="1"
                           Text="DashLook"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,12,0"/>

                <Border Grid.Column="2"
                        Margin="0,8,12,8"
                        Padding="6,4"
                        Background="{DynamicResource HoverBackground}"
                        CornerRadius="12"
                        BorderBrush="{DynamicResource BorderLight}"
                        BorderThickness="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PinButton"
                                Content="Pin"
                                MinWidth="54"
                                Margin="0,0,6,0"
                                Style="{StaticResource TitleBarButton}"
                                ToolTip="Keep this preview on top"
                                Click="PinButton_Click"/>
                        <Button x:Name="OpenExternalBtn"
                                Content="Open"
                                MinWidth="68"
                                Margin="0,0,6,0"
                                Style="{StaticResource TitleBarButton}"
                                ToolTip="Open with the default app"
                                Click="OpenExternal_Click"/>
                        <Button x:Name="CloseBtn"
                                Content="X"
                                Style="{StaticResource CloseButton}"
                                Click="Close_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Background="{DynamicResource ContentBackground}">
                <Grid>
                    <ContentPresenter x:Name="ViewerHost"/>

                    <Grid x:Name="LoadingOverlay" Visibility="Visible">
                        <Border Width="280"
                                Padding="24,22"
                                Background="{DynamicResource WindowBackground}"
                                BorderBrush="{DynamicResource BorderLight}"
                                BorderThickness="1"
                                CornerRadius="18"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <StackPanel>
                                <Image Source="/Resources/dashlook_tray.ico"
                                       Width="40"
                                       Height="40"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"/>
                                <TextBlock Text="DashLook"
                                           Margin="0,14,0,0"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="LoadingText"
                                           Text="Preparing preview..."
                                           Margin="0,8,0,0"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="13"
                                           HorizontalAlignment="Center"/>
                                <ProgressBar Margin="0,16,0,0"
                                             Height="5"
                                             IsIndeterminate="True"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="ErrorOverlay" Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Preview unavailable"
                                       Foreground="{DynamicResource ErrorColor}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="ErrorText"
                                       Text="Cannot preview this file."
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       Margin="0,12,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Background="{DynamicResource StatusBarBackground}"
                    CornerRadius="0,0,12,12">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="FileTypeText"
                               Grid.Column="0"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               VerticalAlignment="Center"/>

                    <TextBlock x:Name="FileSizeText"
                               Grid.Column="1"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"/>

                    <TextBlock Grid.Column="2"
                               Text="[P] Pin  [Enter] Open  [Space/Esc] Close"
                               Foreground="{DynamicResource TextDisabled}"
                               FontSize="10"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
