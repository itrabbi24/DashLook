<UserControl x:Class="DashLook.Plugin.FontViewer.FontViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBackground}">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="{DynamicResource ContentBackground}">
        <StackPanel Margin="32">
            <TextBlock x:Name="FontNameText"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{DynamicResource AccentColor}"
                       Margin="0,0,0,8"/>
            <TextBlock x:Name="FontDetailText"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondary}"
                       Margin="0,0,0,24"/>

            <TextBlock Text="Size 48" Foreground="{DynamicResource TextDisabled}" FontSize="11" Margin="0,0,0,4"/>
            <TextBlock x:Name="Sample48" FontSize="48" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"
                       TextWrapping="Wrap"/>

            <TextBlock Text="Size 32" Foreground="{DynamicResource TextDisabled}" FontSize="11" Margin="0,0,0,4"/>
            <TextBlock x:Name="Sample32" FontSize="32" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"
                       TextWrapping="Wrap"/>

            <TextBlock Text="Size 20" Foreground="{DynamicResource TextDisabled}" FontSize="11" Margin="0,0,0,4"/>
            <TextBlock x:Name="Sample20" FontSize="20" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"
                       TextWrapping="Wrap"/>

            <TextBlock Text="Size 14" Foreground="{DynamicResource TextDisabled}" FontSize="11" Margin="0,0,0,4"/>
            <TextBlock x:Name="Sample14" FontSize="14" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"
                       TextWrapping="Wrap"/>

            <Separator Background="{DynamicResource BorderColor}" Margin="0,8,0,16"/>
            <TextBlock Text="Alphabet" Foreground="{DynamicResource TextDisabled}" FontSize="11" Margin="0,0,0,4"/>
            <TextBlock x:Name="AlphabetText"
                       Text="AaBbCcDdEeFfGgHhIiJjKkLlMmNnOoPpQqRrSsTtUuVvWwXxYyZz"
                       FontSize="18"
                       Foreground="{DynamicResource TextPrimary}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>
            <TextBlock x:Name="NumbersText"
                       Text="0123456789 !@#$%^&amp;*()_+-=[]{}|;':&quot;,.&lt;&gt;?"
                       FontSize="18"
                       Foreground="{DynamicResource TextSecondary}"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
