<UserControl x:Class="DashLook.Plugin.FolderViewer.FolderViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="420"
             d:DesignWidth="860">
    <Grid Background="{DynamicResource ContentBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="32,24,20,24">
            <Border Width="204"
                    Height="156"
                    CornerRadius="24"
                    Background="#FFE7B32E"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid>
                    <Border Width="112"
                            Height="34"
                            Background="#FFF59E0B"
                            CornerRadius="16,16,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="18,18,0,0"/>
                    <Border Width="204"
                            Height="122"
                            Background="#FFFDE68A"
                            CornerRadius="18"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom">
                        <Grid>
                            <Rectangle Width="136"
                                       Height="12"
                                       RadiusX="6"
                                       RadiusY="6"
                                       Fill="#FFFFFFFF"
                                       HorizontalAlignment="Left"
                                       Margin="18,18,0,0"
                                       VerticalAlignment="Top"/>
                            <Rectangle Width="114"
                                       Height="12"
                                       RadiusX="6"
                                       RadiusY="6"
                                       Fill="#FFF8FAFC"
                                       HorizontalAlignment="Left"
                                       Margin="18,42,0,0"
                                       VerticalAlignment="Top"
                                       Opacity="0.9"/>
                            <Rectangle Width="92"
                                       Height="12"
                                       RadiusX="6"
                                       RadiusY="6"
                                       Fill="#FFF8FAFC"
                                       HorizontalAlignment="Left"
                                       Margin="18,66,0,0"
                                       VerticalAlignment="Top"
                                       Opacity="0.72"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Column="1" Margin="12,44,36,24" VerticalAlignment="Center">
            <TextBlock Text="Folder Preview"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentColor}"/>
            <TextBlock x:Name="FolderNameText"
                       Margin="0,8,0,0"
                       FontSize="34"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"
                       TextWrapping="Wrap"/>
            <TextBlock x:Name="ModifiedText"
                       Margin="0,18,0,0"
                       FontSize="15"
                       Foreground="{DynamicResource TextSecondary}"/>
            <TextBlock x:Name="SummaryText"
                       Margin="0,12,0,0"
                       FontSize="18"
                       Foreground="{DynamicResource TextPrimary}"
                       FontWeight="SemiBold"/>

            <WrapPanel Margin="0,28,0,0" ItemHeight="86" ItemWidth="188">
                <Border Background="{DynamicResource WindowBackground}"
                        BorderBrush="{DynamicResource BorderLight}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14,10"
                        Margin="0,0,14,14">
                    <StackPanel>
                        <TextBlock Text="Folders" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock x:Name="FolderCountText" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource WindowBackground}"
                        BorderBrush="{DynamicResource BorderLight}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14,10"
                        Margin="0,0,14,14">
                    <StackPanel>
                        <TextBlock Text="Files" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock x:Name="FileCountText" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource WindowBackground}"
                        BorderBrush="{DynamicResource BorderLight}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14,10"
                        Margin="0,0,14,14">
                    <StackPanel>
                        <TextBlock Text="Size" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock x:Name="SizeText" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </StackPanel>
    </Grid>
</UserControl>
