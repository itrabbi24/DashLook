<?xml version="1.0" encoding="UTF-8"?>
<!--
  DashLook WiX v5 Installer
  Developer: ARG RABBI — https://itrabbi24.github.io/
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="DashLook"
           Manufacturer="ARG RABBI"
           Version="$(var.AppVersion)"
           UpgradeCode="DCA7F3B1-4E2A-4F3D-9B1C-8E2D7A4B5C6F"
           Language="1033"
           Codepage="1252"
           InstallerVersion="500"
           Compressed="yes">

    <SummaryInformation Description="DashLook — Instant file preview for Windows. Developed by ARG RABBI (itrabbi24.github.io)"/>

    <MajorUpgrade DowngradeErrorMessage="A newer version of DashLook is already installed." />

    <MediaTemplate EmbedCab="yes"/>

    <!-- ── UI ────────────────────────────────────────────────────────────── -->
    <ui:WixUI Id="WixUI_InstallDir"/>
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER"/>

    <Property Id="WIXUI_EXITDIALOGOPTIONALTEXT"
              Value="DashLook is ready! Press Space in File Explorer to preview any file.&#10;&#10;Developed by ARG RABBI — itrabbi24.github.io" />

    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT"
              Value="Visit developer website (itrabbi24.github.io)" />

    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1"/>

    <!-- ── Launch app after install ──────────────────────────────────────── -->
    <Property Id="WixShellExecTarget" Value="[INSTALLFOLDER]DashLook.exe"/>
    <CustomAction Id="LaunchAppOnExit"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixShellExec"
                  Impersonate="yes"
                  Return="ignore"/>

    <InstallExecuteSequence>
      <Custom Action="LaunchAppOnExit"
              After="InstallFinalize"
              Condition="NOT Installed AND NOT REMOVE"/>
    </InstallExecuteSequence>

    <!-- ── Install directory ──────────────────────────────────────────────── -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="DashLook">
        <Directory Id="PLUGINSFOLDER" Name="Plugins"/>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="DashLook"/>
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder"/>

    <!-- ── Main executable ───────────────────────────────────────────────── -->
    <ComponentGroup Id="MainApp" Directory="INSTALLFOLDER">
      <Component Id="DashLookExe" Guid="A1B2C3D4-1111-1111-1111-111111111111">
        <File Id="DashLookExeFile"
              Source="$(var.PublishDir)\DashLook.exe"
              KeyPath="yes"/>
        <!-- Auto-start on Windows login -->
        <RegistryValue Root="HKCU"
                       Key="Software\Microsoft\Windows\CurrentVersion\Run"
                       Name="DashLook"
                       Value="[INSTALLFOLDER]DashLook.exe"
                       Type="string"/>
        <!-- Developer info -->
        <RegistryValue Root="HKCU"
                       Key="Software\DashLook"
                       Name="Developer"
                       Value="ARG RABBI — https://itrabbi24.github.io/"
                       Type="string"/>
        <RegistryValue Root="HKCU"
                       Key="Software\DashLook"
                       Name="Version"
                       Value="$(var.AppVersion)"
                       Type="string"/>
      </Component>
    </ComponentGroup>

    <!-- ── Start menu shortcuts ───────────────────────────────────────────── -->
    <ComponentGroup Id="Shortcuts" Directory="ApplicationProgramsFolder">
      <Component Id="StartMenuShortcut" Guid="C3D4E5F6-3333-3333-3333-333333333333">
        <Shortcut Id="StartMenuShortcutDashLook"
                  Name="DashLook"
                  Description="Instant file preview — by ARG RABBI"
                  Target="[INSTALLFOLDER]DashLook.exe"
                  WorkingDirectory="INSTALLFOLDER"/>
        <Shortcut Id="StartMenuShortcutWebsite"
                  Name="DashLook — Developer Website"
                  Description="Visit ARG RABBI's developer profile"
                  Target="https://itrabbi24.github.io/"/>
        <RemoveFolder Id="RemoveStartMenu" On="uninstall"/>
        <RegistryValue Root="HKCU"
                       Key="Software\DashLook"
                       Name="Installed"
                       Value="1"
                       Type="integer"
                       KeyPath="yes"/>
      </Component>
    </ComponentGroup>

    <!-- ── Desktop shortcut ───────────────────────────────────────────────── -->
    <ComponentGroup Id="DesktopShortcuts" Directory="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="D4E5F6A7-4444-4444-4444-444444444444">
        <Shortcut Id="DesktopShortcutDashLook"
                  Name="DashLook"
                  Description="Instant file preview for Windows"
                  Target="[INSTALLFOLDER]DashLook.exe"
                  WorkingDirectory="INSTALLFOLDER"/>
        <RegistryValue Root="HKCU"
                       Key="Software\DashLook"
                       Name="DesktopShortcut"
                       Value="1"
                       Type="integer"
                       KeyPath="yes"/>
      </Component>
    </ComponentGroup>

    <!-- ── Feature ───────────────────────────────────────────────────────── -->
    <Feature Id="Complete" Title="DashLook" Level="1">
      <ComponentGroupRef Id="MainApp"/>
      <ComponentGroupRef Id="Shortcuts"/>
      <ComponentGroupRef Id="DesktopShortcuts"/>
    </Feature>

  </Package>
</Wix>
